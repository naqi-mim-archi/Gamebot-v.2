{
  "index.html": "<!DOCTYPE html><html><head><meta charset='UTF-8'><title>2-Player Pong</title><style>*{margin:0;padding:0;box-sizing:border-box;}body{background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;font-family:monospace;overflow:hidden;}canvas{display:block;}#status{color:#aaa;font-size:13px;margin-top:8px;height:18px;text-align:center;}#overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;gap:16px;z-index:10;}#overlay h2{font-size:22px;font-weight:900;letter-spacing:.1em;}#overlay p{font-size:13px;color:#aaa;text-align:center;max-width:280px;line-height:1.6;}#overlay.hidden{display:none;}</style></head><body><div id='overlay'><h2>2-PLAYER PONG</h2><p id='overlayMsg'>Waiting for multiplayer connection...<br>Use the Play with Friend button to connect.</p></div><canvas id='c'></canvas><div id='status'></div><script>(function(){\nvar cv=document.getElementById('c'),ctx=cv.getContext('2d'),overlay=document.getElementById('overlay'),statusEl=document.getElementById('status');\nvar W=640,H=400;cv.width=W;cv.height=H;\nvar PH=80,PW=12,BR=8,playerIndex=null;\nvar state={p0y:H/2-PH/2,p1y:H/2-PH/2,bx:W/2,by:H/2,vx:4,vy:2,score:[0,0],running:false};\nvar keys={};\ndocument.addEventListener('keydown',function(e){keys[e.key]=true;e.preventDefault();});\ndocument.addEventListener('keyup',function(e){keys[e.key]=false;});\nfunction send(data){window.parent.postMessage({type:'MP_SEND',data:data},'*');}\nwindow.addEventListener('message',function(e){\n  var d=e.data;if(!d||typeof d!=='object')return;\n  if(d.type==='MP_INIT'){playerIndex=d.playerIndex;overlay.classList.add('hidden');state.running=true;statusEl.textContent=playerIndex===0?'You are Player 1 — W/S keys':'You are Player 2 — Arrow keys';loop();}\n  if(d.type==='MP_RECV'){var ev=d.data;\n    if(ev.type==='paddle'){if(playerIndex===0)state.p1y=ev.y;else state.p0y=ev.y;}\n    if(ev.type==='ball'&&playerIndex===1){state.bx=ev.x;state.by=ev.y;state.vx=ev.vx;state.vy=ev.vy;}\n    if(ev.type==='score'){state.score=ev.score;}\n  }\n});\nvar lastY=null;\nfunction update(){\n  if(playerIndex===0){\n    if((keys['w']||keys['W'])&&state.p0y>0)state.p0y-=5;\n    if((keys['s']||keys['S'])&&state.p0y<H-PH)state.p0y+=5;\n    if(state.p0y!==lastY){send({type:'paddle',y:state.p0y});lastY=state.p0y;}\n    state.bx+=state.vx;state.by+=state.vy;\n    if(state.by-BR<0){state.by=BR;state.vy=Math.abs(state.vy);}\n    if(state.by+BR>H){state.by=H-BR;state.vy=-Math.abs(state.vy);}\n    if(state.bx-BR<PW+8&&state.by>=state.p0y&&state.by<=state.p0y+PH&&state.vx<0){state.vx=Math.abs(state.vx)+.15;state.vy+=(state.by-(state.p0y+PH/2))*.05;}\n    if(state.bx+BR>W-PW-8&&state.by>=state.p1y&&state.by<=state.p1y+PH&&state.vx>0){state.vx=-(Math.abs(state.vx)+.15);state.vy+=(state.by-(state.p1y+PH/2))*.05;}\n    var spd=Math.sqrt(state.vx*state.vx+state.vy*state.vy);if(spd>14){state.vx=state.vx/spd*14;state.vy=state.vy/spd*14;}\n    if(state.bx<0){state.score[1]++;reset();}\n    if(state.bx>W){state.score[0]++;reset();}\n    send({type:'ball',x:state.bx,y:state.by,vx:state.vx,vy:state.vy});\n    send({type:'score',score:state.score});\n  }else{\n    if(keys['ArrowUp']&&state.p1y>0)state.p1y-=5;\n    if(keys['ArrowDown']&&state.p1y<H-PH)state.p1y+=5;\n    if(state.p1y!==lastY){send({type:'paddle',y:state.p1y});lastY=state.p1y;}\n  }\n}\nfunction reset(){state.bx=W/2;state.by=H/2;state.vx=4*(Math.random()>.5?1:-1);state.vy=2*(Math.random()>.5?1:-1);}\nfunction draw(){\n  ctx.fillStyle='#000';ctx.fillRect(0,0,W,H);\n  ctx.setLineDash([10,10]);ctx.strokeStyle='rgba(255,255,255,.15)';ctx.lineWidth=2;\n  ctx.beginPath();ctx.moveTo(W/2,0);ctx.lineTo(W/2,H);ctx.stroke();ctx.setLineDash([]);\n  ctx.font='bold 48px monospace';ctx.textAlign='center';ctx.fillStyle='rgba(255,255,255,.5)';\n  ctx.fillText(state.score[0],W/4,60);ctx.fillText(state.score[1],3*W/4,60);\n  ctx.fillStyle='#fff';ctx.fillRect(8,state.p0y,PW,PH);ctx.fillRect(W-PW-8,state.p1y,PW,PH);\n  ctx.save();ctx.shadowColor='#fff';ctx.shadowBlur=18;ctx.fillStyle='#fff';\n  ctx.beginPath();ctx.arc(state.bx,state.by,BR,0,Math.PI*2);ctx.fill();ctx.restore();\n  ctx.font='11px monospace';ctx.fillStyle='rgba(255,255,255,.3)';\n  ctx.textAlign='left';ctx.fillText('P1',10,H-8);ctx.textAlign='right';ctx.fillText('P2',W-10,H-8);\n}\nfunction loop(){if(!state.running)return;update();draw();requestAnimationFrame(loop);}\nwindow.parent.postMessage({type:'MP_GAME_LOADED'},'*');\n})();<\/script></body></html>"
}
