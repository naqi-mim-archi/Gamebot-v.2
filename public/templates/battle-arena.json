  "index.html": "<!DOCTYPE html><html><head><meta charset='UTF-8'><title>Battle Arena 2P</title><style>*{margin:0;padding:0;box-sizing:border-box;}body{background:#0a0a12;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;font-family:monospace;overflow:hidden;}canvas{display:block;border:1px solid rgba(255,255,255,.08);border-radius:8px;}#status{color:#888;font-size:12px;margin-top:6px;height:16px;text-align:center;}#overlay{position:fixed;inset:0;background:rgba(0,0,0,.88);display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;gap:14px;z-index:10;}#overlay h2{font-size:20px;font-weight:900;letter-spacing:.08em;}#overlay p{font-size:12px;color:#aaa;text-align:center;max-width:260px;line-height:1.7;}#overlay.hidden{display:none;}</style></head><body><div id='overlay'><h2>BATTLE ARENA</h2><p>2-Player Online Combat<br>Use Play with Friend to connect.</p></div><canvas id='c'></canvas><div id='status'></div><script>(function(){\nvar cv=document.getElementById('c'),ctx=cv.getContext('2d'),overlay=document.getElementById('overlay'),statusEl=document.getElementById('status');\nvar W=600,H=400;cv.width=W;cv.height=H;\nvar G=0.45,SPEED=3.5,JUMP=-11,ATK_R=38,ATKCOOL=30;\nvar playerIndex=null;\nvar players=[\n  {x:80,y:300,vx:0,vy:0,hp:100,face:1,atk:0,hit:0,dead:false,col:'#4fc3f7',name:'P1'},\n  {x:520,y:300,vx:0,vy:0,hp:100,face:-1,atk:0,hit:0,dead:false,col:'#f48fb1',name:'P2'}\n];\nvar platforms=[{x:0,y:370,w:W,h:30},{x:80,y:280,w:140,h:14},{x:380,y:280,w:140,h:14},{x:210,y:200,w:180,h:14}];\nvar keys={},particles=[];\ndocument.addEventListener('keydown',function(e){keys[e.key]=true;e.preventDefault();});\ndocument.addEventListener('keyup',function(e){keys[e.key]=false;});\nfunction send(data){window.parent.postMessage({type:'MP_SEND',data:data},'*');}\nwindow.addEventListener('message',function(e){\n  var d=e.data;if(!d||typeof d!=='object')return;\n  if(d.type==='MP_INIT'){playerIndex=d.playerIndex;overlay.classList.add('hidden');statusEl.textContent=playerIndex===0?'You: P1 (WASD + F to attack)':'You: P2 (Arrow keys + L to attack)';loop();}\n  if(d.type==='MP_RECV'){var ev=d.data;\n    if(ev.type==='pos'){var op=players[playerIndex===0?1:0];op.x=ev.x;op.y=ev.y;op.vx=ev.vx;op.vy=ev.vy;op.face=ev.face;op.atk=ev.atk;}\n    if(ev.type==='hit'){var me=players[playerIndex];me.hp=Math.max(0,me.hp-ev.dmg);me.hit=12;\n      for(var i=0;i<8;i++)particles.push({x:me.x,y:me.y-30,vx:(Math.random()-.5)*5,vy:-Math.random()*4,l:18,col:'#ff5252'});}\n  }\n});\nfunction onGround(p){\n  for(var i=0;i<platforms.length;i++){var pl=platforms[i];if(p.x+12>pl.x&&p.x-12<pl.x+pl.w&&p.y>pl.y-4&&p.y<pl.y+pl.h+4&&p.vy>=0)return pl.y;}\n  return null;\n}\nvar lastSent={x:null,y:null};\nfunction update(){\n  var me=players[playerIndex],op=players[playerIndex===0?1:0];\n  var left=playerIndex===0?(keys['a']||keys['A']):(keys['ArrowLeft']);\n  var right=playerIndex===0?(keys['d']||keys['D']):(keys['ArrowRight']);\n  var jump=playerIndex===0?(keys['w']||keys['W']):(keys['ArrowUp']);\n  var attack=playerIndex===0?(keys['f']||keys['F']):(keys['l']||keys['L']);\n  if(left){me.vx=-SPEED;me.face=-1;}else if(right){me.vx=SPEED;me.face=1;}else me.vx*=.7;\n  me.vy+=G;\n  var gnd=onGround(me);\n  if(gnd!==null){me.y=gnd;me.vy=0;if(jump){me.vy=JUMP;}}\n  me.x+=me.vx;me.y+=me.vy;\n  me.x=Math.max(12,Math.min(W-12,me.x));me.y=Math.min(H+60,me.y);\n  if(me.y>H+50){me.hp=Math.max(0,me.hp-25);me.x=playerIndex===0?80:520;me.y=250;me.vy=0;}\n  if(me.atk>0)me.atk--;\n  if(me.hit>0)me.hit--;\n  if(attack&&me.atk===0&&!me.dead){\n    me.atk=ATKCOOL;\n    var dx=op.x-me.x,dy=(op.y-30)-(me.y-30),dist=Math.sqrt(dx*dx+dy*dy);\n    if(dist<ATK_R){send({type:'hit',dmg:12});}\n  }\n  if(me.x!==lastSent.x||me.y!==lastSent.y){\n    send({type:'pos',x:me.x,y:me.y,vx:me.vx,vy:me.vy,face:me.face,atk:me.atk});\n    lastSent.x=me.x;lastSent.y=me.y;\n  }\n  particles=particles.filter(function(p){p.x+=p.vx;p.y+=p.vy;p.vy+=.2;p.l--;ctx.globalAlpha=p.l/18;ctx.fillStyle=p.col;ctx.fillRect(p.x,p.y,3,3);return p.l>0;});ctx.globalAlpha=1;\n}\nfunction drawPlayer(p,idx){\n  if(p.y>H+10)return;\n  ctx.save();\n  if(p.hit>0){ctx.globalAlpha=.4+.6*Math.sin(p.hit*1.5);}\n  var glow=p.atk>ATKCOOL-8;\n  if(glow){ctx.shadowColor=p.col;ctx.shadowBlur=22;}\n  ctx.fillStyle=p.col;\n  // Body\n  ctx.fillRect(p.x-14,p.y-52,28,36);\n  // Head\n  ctx.beginPath();ctx.arc(p.x,p.y-60,13,0,Math.PI*2);ctx.fill();\n  // Legs\n  ctx.fillRect(p.x-12,p.y-16,10,18);ctx.fillRect(p.x+2,p.y-16,10,18);\n  // Eyes\n  ctx.fillStyle='rgba(0,0,0,.6)';\n  ctx.fillRect(p.x+p.face*2,p.y-64,5,5);\n  // Attack arc\n  if(glow){\n    ctx.strokeStyle=p.col;ctx.lineWidth=3;ctx.globalAlpha=.5;\n    ctx.beginPath();ctx.arc(p.x+p.face*20,p.y-30,ATK_R*.6,0,Math.PI*2);ctx.stroke();\n  }\n  // HP bar\n  ctx.globalAlpha=1;ctx.fillStyle='#333';ctx.fillRect(p.x-22,p.y-76,44,5);\n  ctx.fillStyle=p.hp>50?'#4caf50':p.hp>25?'#ff9800':'#f44336';\n  ctx.fillRect(p.x-22,p.y-76,44*(p.hp/100),5);\n  ctx.restore();\n}\nfunction draw(){\n  var bg=ctx.createLinearGradient(0,0,0,H);bg.addColorStop(0,'#0a0a18');bg.addColorStop(1,'#1a1a30');\n  ctx.fillStyle=bg;ctx.fillRect(0,0,W,H);\n  platforms.forEach(function(pl,i){\n    var g=ctx.createLinearGradient(0,pl.y,0,pl.y+pl.h);\n    g.addColorStop(0,i===0?'#2e7d32':'#1b5e20');g.addColorStop(1,i===0?'#1b5e20':'#0d3018');\n    ctx.fillStyle=g;ctx.fillRect(pl.x,pl.y,pl.w,pl.h);\n    ctx.fillStyle='rgba(255,255,255,.08)';ctx.fillRect(pl.x,pl.y,pl.w,2);\n  });\n  drawPlayer(players[0],0);drawPlayer(players[1],1);\n  // Top HUD\n  ctx.font='bold 13px monospace';\n  ctx.fillStyle=players[0].col;ctx.textAlign='left';ctx.fillText('P1: '+players[0].hp+'HP',10,22);\n  ctx.fillStyle=players[1].col;ctx.textAlign='right';ctx.fillText('P2: '+players[1].hp+'HP',W-10,22);\n  if(players[0].hp<=0||players[1].hp<=0){\n    ctx.fillStyle='rgba(0,0,0,.6)';ctx.fillRect(0,0,W,H);\n    ctx.font='bold 36px monospace';ctx.fillStyle='#fff';ctx.textAlign='center';\n    var winner=players[0].hp<=0?'P2':'P1';\n    ctx.fillText(winner+' WINS!',W/2,H/2);\n    ctx.font='14px monospace';ctx.fillStyle='#aaa';ctx.fillText('Refresh to play again',W/2,H/2+36);\n  }\n}\nfunction loop(){update();draw();requestAnimationFrame(loop);}\nwindow.parent.postMessage({type:'MP_GAME_LOADED'},'*');\n})();<\/script></body></html>"
}
