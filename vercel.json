{
  "buildCommand": "echo 'skip'",
  "outputDirectory": "dist",
  "installCommand": "npm install --ignore-scripts",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
